# Node modules (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output (will be created in container)
dist/
build/

# Environment files (should be provided at build time)
.env
.env.local
.env.*.local

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/

# Documentation
README.md
docs/

# Docker (exclude only root-level docker files, keep nginx config)
Dockerfile
.dockerignore
docker-compose.yml
!nginx/

# Temporary files
tmp/
temp/
*.tmp
